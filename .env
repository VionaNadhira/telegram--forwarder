# Telegram Credentials
# Get API_ID and API_HASH from https://my.telegram.org
API_ID=
API_HASH=
# String session generated after first interactive login (leave blank initially)
STRING_SESSION=

# Telegram Source Channel/Group username, chat ID (e.g. -100xxx), or title
TELEGRAM_CHAT=

# Discord Credentials
DISCORD_TOKEN=
DISCORD_CHANNEL_ID=

# Customization Options
# Embed Color hex code (default is Discord Blurple #5865F2)
EMBED_COLOR=#5865F2

# Forward message edits
FORWARD_EDITS=false

# Media forward configuration
DOWNLOAD_MEDIA=true
DELETE_TEMP_FILES=true
# Discord's upload limit for normal accounts is usually 25MB (or 10MB/50MB depending on boosts). 
# Default to 24MB to avoid exceeding limits.
MAX_FILE_SIZE_MB=24

# Message display format
SEND_AS_EMBED=true

# Reconnection configuration (in milliseconds)
RECONNECT_DELAY=5000
